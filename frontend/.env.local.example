# ─── Local Development (.env.local) ──────────────────────────────────
# Copy this file to .env.local and fill in values.
# .env.local is git-ignored — never commit real secrets.

# Leave empty → Vite proxy routes /api to localhost:8080
VITE_API_BASE_URL=

VITE_RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY
VITE_APP_NAME=VehicleRent
