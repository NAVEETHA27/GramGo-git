# ─── VehicleRent Frontend Environment Variables ──────────────────────
#
# Copy this file to .env.local for local development.
# For Vercel: add these in the Vercel dashboard under
#   Project → Settings → Environment Variables
#
# IMPORTANT: All browser-visible variables MUST start with VITE_

# ── API Base URL ──────────────────────────────────────────────────────
# Leave empty for local development (Vite proxy handles /api → localhost:8080)
# Set to your deployed backend URL for staging / production:
#   e.g. https://api.vehiclerent.com  OR  https://your-ec2-ip.compute.amazonaws.com
#
# DO NOT include /api at the end — the app appends it automatically.
VITE_API_BASE_URL=

# ── Razorpay ──────────────────────────────────────────────────────────
# Your Razorpay Key ID (publishable — safe to expose in browser)
# Test:  rzp_test_XXXXXXXXXX
# Live:  rzp_live_XXXXXXXXXX
VITE_RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY

# ── Google Maps ───────────────────────────────────────────────────────
# Required if using Google Maps embeds (optional — OpenStreetMap is used by default)
VITE_GOOGLE_MAPS_API_KEY=

# ── App info ──────────────────────────────────────────────────────────
VITE_APP_NAME=VehicleRent
VITE_APP_VERSION=1.0.0
